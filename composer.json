{
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "ext-pdo": "*",
        "firebase/php-jwt": "6.10.0",
        "mpdf/mpdf": "^8.3",
        "phpoffice/phpspreadsheet": "1.30.4",
        "symfony/dotenv": "5.4.48"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app"
        },
        "files": ["app/helpers.php"]
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/var-dumper": "5.4.48"
    },
    "scripts": {
        "format": ["phpcbf"],
        "serve": "php -S localhost:61001 -t public",
        "post-autoload-dump": "php -r \"if (!file_exists('.env')) copy('.env.example', '.env');\"",
        "lint": ["phpstan --memory-limit=1G"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "process-timeout": 0,
        "audit": {
            "ignore": ["firebase/php-jwt"]
        }
    }
}
